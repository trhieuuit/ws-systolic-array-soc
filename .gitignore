# =========================================
*.jou
*.log
*.str

# =========================================
# 2. Các thư mục rác và file tạm của Vivado
# =========================================
.Xil/
*.cache/
*.hw/
*.ip_user_files/
*.runs/
*.sim/
*.gen/
*.tmp/

# =========================================
