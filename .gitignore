# =========================================
*.pb
*.wdb
*.wcfg

# =========================================
# 5. File Project và Block Design rác
# (Vì chúng ta đã dùng lệnh Tcl để khôi phục)
# =========================================
*.xpr
*.bxml

# =========================================
# 6. Các file biên dịch phần mềm (cho thư mục codeC)
# =========================================
*.o
*.elf
*.bin
.vitis/

# =========================================
# 7. File rác của Hệ điều hành
# =========================================
.DS_Store
Thumbs.db